# Tranzy.ai credentials — sign up at https://tranzy.dev/accounts
TRANZY_API_KEY=
TRANZY_AGENCY_ID=2

# Transitous seed URL (defaults to the official Cluj-Napoca mirror)
TRANSITOUS_SEED_URL=https://api.transitous.org/gtfs/ro_Cluj-Napoca.gtfs.zip

# Output
GTFS_OUTPUT_DIR=./output
GTFS_OUTPUT_NAME=cluj-napoca.gtfs.zip

# CTP CSV schedule scraping
CTP_CSV_BASE_URL=https://ctpcj.ro/orare/csv/orar_{routeShortName}_{serviceId}.csv
CTP_SERVICE_KEYS=lv,s,d,ld

# Calendar — derive start/end from today
GTFS_CALENDAR_DAYS=180
GTFS_TIMEZONE=Europe/Bucharest

# Tranzy throttling (free tier is generous; 0 disables)
TRANZY_RATE_LIMIT_MS=500

# Logging
LOG_LEVEL=info