{
  "name": "cluj-napoca-gtfs-adapter",
  "version": "0.1.3",
  "private": false,
  "type": "module",
  "description": "Reconciled GTFS Schedule publisher for Cluj-Napoca (CTP) — combines Transitous seed, Tranzy.ai live static API, and CTP CSV timetables into the most complete, error-free feed.",
  "main": "src/cli.ts",
  "bin": {
    "cluj-napoca-gtfs": "src/cli.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "build:run": "tsx src/cli.ts build",
    "build:full": "pnpm fetch:csv && pnpm build:run",
    "validate": "tsx src/cli.ts validate",
    "reconcile:dry": "tsx src/cli.ts reconcile --dry-run",
    "fetch:csv": "tsx scripts/fetch-stage.ts",
    "inspect:404s": "tsx scripts/inspect-404s.ts",
    "smoke:trip-ids": "tsx src/verify-rt-parity.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "@n3ary/gtfs-spec": "^0.3.1",
    "archiver": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^10.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "4.1.9"
  },
  "keywords": [
    "gtfs",
    "transit",
    "cluj-napoca",
    "ctp",
    "transitous",
    "tranzy",
    "reconciliation"
  ],
  "license": "PolyForm-Noncommercial-1.0.0"
}
