    "smoke:trip-ids": "tsx src/verify-trip-id-format.ts",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.5.2",
