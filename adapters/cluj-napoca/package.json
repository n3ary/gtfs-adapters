    "gtfs-realtime-bindings": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^10.6.0",
    "protobufjs": "^7.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "4.1.9"
  },
  "keywords": [
    "gtfs",
    "transit",
    "cluj-napoca",
    "ctp",
    "transitous",
    "tranzy",
    "reconciliation"
