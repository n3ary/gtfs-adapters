// Dist is generated by `tsc -p tsconfig.build.json`; not source.
// Never commit. Consumers receive it via the published tarball.
dist/

// pnpm-managed trees — each package has its own, plus the workspace root
// has a hoist tree. The root node_modules is at the workspace root
// (`gtfs-adapters/node_modules`), one level up from this .gitignore.
node_modules/

// AI editor state (per n3ary AGENTS.md: no .claude/, .kiro/, etc. in repos)
// — also excluded from the publish tarball in case it slips in.
.kilo/
.worktrees/
deploy/
*.tsbuildinfo
